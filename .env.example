# ============================================================================
# FastAPI Pydantic AI Agent - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in the values
# Required fields must be set or the application will fail to start

# ============================================================================
# REQUIRED CONFIGURATION
# ============================================================================

# API key for X-API-Key authentication
# Used to protect API endpoints (except /health)
API_KEY=your-api-key-here

# LLM model identifier
# Examples: "openai:gpt-4o", "openai:gpt-4o-mini", "anthropic:claude-3-5-sonnet"
LLM_MODEL=openai:gpt-4o

# ============================================================================
# OPTIONAL CONFIGURATION
# ============================================================================

# API key for LLM provider
# Required for cloud providers (OpenAI, Anthropic)
# Not required for local providers (Ollama) - leave empty if using Ollama
LLM_API_KEY=sk-...

# Custom base URL for LLM provider
# Use for local providers or proxies
# For Ollama, use http://localhost:11434 (WITHOUT /v1)
#   LiteLLM automatically appends /v1 when making requests to Ollama
# Example for Ollama: http://localhost:11434
# Leave empty for default cloud provider endpoints
LLM_BASE_URL=

# Embedding model identifier for semantic search
# Example: "all-MiniLM-L6-v2" (fast, 384-dimensional embeddings)
# Leave empty to use default TF-IDF vector store (no embeddings)
EMBEDDING_MODEL=

# Custom base URL for embedding provider
# Example for Ollama embeddings: http://localhost:11434
# Leave empty when using EMBEDDING_MODEL without custom endpoint
EMBEDDING_BASE_URL=

# Number of retries for Pydantic AI output validation
# Default: 3
MAX_OUTPUT_RETRIES=3

# Application environment (development, staging, production)
# Default: development
# SECURITY: enable_mock_tools cannot be enabled when APP_ENV=production
APP_ENV=development

# Enable mock tools (for development only, disable in production)
# Default: false
# SECURITY: Cannot be enabled when APP_ENV=production
ENABLE_MOCK_TOOLS=false

# Allowed CORS origins (comma-separated or JSON array)
# Default: ["http://localhost:3000"]
# Examples:
#   Single origin: CORS_ORIGINS=https://app.example.com
#   Multiple origins: CORS_ORIGINS=["https://app.example.com","https://admin.example.com"]
#   Development (all origins): CORS_ORIGINS=["*"]
# SECURITY: Use specific domains in production, never use "*" in production
CORS_ORIGINS=["http://localhost:3000"]

# Trusted proxy IP addresses for X-Forwarded-For validation
# Default: [] (empty list - X-Forwarded-For header is never trusted)
# List of IP addresses that are trusted to set X-Forwarded-For header
# Only requests from these IPs will have their X-Forwarded-For header trusted
# Examples:
#   Single proxy: TRUSTED_PROXIES=["10.0.0.1"]
#   Multiple proxies: TRUSTED_PROXIES=["10.0.0.1","10.0.0.2","192.168.1.1"]
# SECURITY: Only add IPs of your actual load balancers/proxies
# SECURITY: Empty list prevents X-Forwarded-For spoofing attacks
TRUSTED_PROXIES=[]

# Maximum retry attempts for LLM API calls
# Default: 3
LLM_RETRY_MAX_ATTEMPTS=3

# Base delay in seconds for exponential backoff retries
# Default: 1.0
LLM_RETRY_BASE_DELAY=1.0

# Timeout in seconds for individual LLM agent execution
# Prevents indefinite hangs during LLM evaluation/synthesis
# Default: 30
# Range: 5-300
LLM_AGENT_TIMEOUT=30

# Timeout in seconds for entire RAG workflow execution
# Covers all steps combined (search + evaluate + synthesize)
# Default: 60
# Range: 5-600
RAG_WORKFLOW_TIMEOUT=60

# Time-to-live in seconds for RAG query result cache
# Cache stores workflow results to avoid redundant LLM calls
# Set to 0 to disable caching
# Default: 300 (5 minutes)
# Range: 0-3600
RAG_CACHE_TTL=300

# Maximum number of entries in RAG query result cache
# Uses LRU eviction when limit is reached
# Default: 100
# Range: 1-10000
RAG_CACHE_SIZE=100

# HTTP client timeout in seconds
# Default: 30.0
HTTP_TIMEOUT=30.0

# HTTP client connection timeout in seconds
# Default: 5.0
HTTP_CONNECT_TIMEOUT=5.0

# Maximum number of HTTP connections in the pool
# Default: 100
# Range: 1-500
HTTP_MAX_CONNECTIONS=100

# Maximum number of keep-alive HTTP connections in the pool
# Default: 20
# Range: 1-100
# Note: Must not exceed HTTP_MAX_CONNECTIONS
HTTP_MAX_KEEPALIVE_CONNECTIONS=20

# Maximum retry attempts for HTTP client requests on transient failures
# Network errors and 5xx server errors trigger retries with exponential backoff
# Default: 3
# Range: 1-10
HTTP_RETRY_MAX_ATTEMPTS=3

# Base delay in seconds for exponential backoff retries in HTTP client
# Actual delay: base_delay * (2 ** attempt) + random jitter
# Default: 1.0
# Range: 0.1-10.0
HTTP_RETRY_BASE_DELAY=1.0

# ============================================================================
# REDIS SESSION STORE ()
# ============================================================================
# Enable Redis-backed session store for multi-instance deployments
# If disabled or not configured, uses in-memory session store
# In-memory store is suitable for development and single-instance deployments only

# Redis connection URL
# Format: redis://[user:password@]host:port/db
# Examples:
#   Local Redis: redis://localhost:6379/0
#   Redis with auth: redis://:password@localhost:6379/0
#   Redis Cloud: redis://:password@redis-12345.cloud.redislabs.com:12345/0
# Leave empty to use in-memory session store
REDIS_URL=

# Enable Redis session store
# Set to true to use Redis for session storage (requires REDIS_URL to be set)
# Set to false to use in-memory session store (default)
# Default: false
REDIS_SESSION_STORE_ENABLED=false

# ============================================================================
# OBSERVABILITY
# ============================================================================

# Pydantic Logfire token for observability
# Get your token from https://logfire.pydantic.dev/
# Leave empty to disable Logfire integration
LOGFIRE_TOKEN=

# Service name for Logfire traces
# Default: fastapi-pydantic-ai-agent
LOGFIRE_SERVICE_NAME=fastapi-pydantic-ai-agent

# ============================================================================
# OLLAMA LOCAL DEVELOPMENT (Optional)
# ============================================================================
# Use Ollama as a local LLM provider (no API key required)
#
# 1. Install Ollama: https://ollama.com
# 2. Start server: ollama serve
# 3. Pull models:
#    ollama pull granite3.3:latest
#    ollama pull granite3.3:latest
#    ollama pull nomic-embed-text:latest  # for OllamaEmbeddingVectorStore
#
# Example LLM configuration with Ollama:
# LLM_MODEL=ollama:granite3.3:latest
# LLM_BASE_URL=http://localhost:11434  # Optional, WITHOUT /v1 (LiteLLM adds it)
# LLM_API_KEY is NOT required for Ollama (local provider)
#
# Example embedding configuration (enables semantic search):
# EMBEDDING_MODEL=nomic-embed-text:latest
# EMBEDDING_BASE_URL=http://localhost:11434/v1  # WITH /v1 (direct API call, no LiteLLM)
#
# Note the URL difference:
#   - LLM_BASE_URL: no /v1 (LiteLLM appends it automatically)
#   - EMBEDDING_BASE_URL: with /v1 (calls Ollama API directly, not via LiteLLM)
#
# Note: When using Ollama, the LLM_MODEL format is "ollama:<model>:<tag>"
# Examples:
#   - ollama:granite3.3:latest
#   - ollama:granite3.3:latest
#   - ollama:llama3.2